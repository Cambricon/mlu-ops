op_name: "logspace"
input {
  id: "input"
  shape: {
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_FLOAT
  random_data: {
    seed: 23
    upper_bound: 100
    lower_bound: -100
    distribution: UNIFORM
  }
}
output {
  id: "output"
  shape: {
    dims: 128
  }
  layout: LAYOUT_ARRAY
  dtype: DTYPE_BFLOAT16
}

logspace_param {
  start: 1
  end: 3
  steps: 128
  base: 10
}

test_param: {
  error_func: DIFF1
  error_func: DIFF2
  error_threshold: 0.003
  error_threshold: 0.003
  baseline_device: CPU
}
